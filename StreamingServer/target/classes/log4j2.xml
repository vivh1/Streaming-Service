<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="INFO">
    <Appenders>
        <Console name="console" target="SYSTEM_OUT">
            <PatternLayout
                pattern="[%-5level] %d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %c{1} - %msg%n" />
        </Console>
        <File name="statsFile" fileName="stats.log" append="true">
            <PatternLayout pattern="=== %d{yyyy-MM-dd HH:mm:ss} ===%n%msg%n%n" />
        </File>
    </Appenders>
    
    <Loggers>
        <Logger name="StatsLogger" level="info" additivity="true">
            <AppenderRef ref="statsFile" />
        </Logger>
        <Root level="all" additivity="true">
            <AppenderRef ref="console" />
        </Root>
    </Loggers>
</Configuration>